# Пример конфигурации - скопируйте в .env и измените значения

# Приложение
APP_NAME=URL Shortener
DEBUG=True

# База данных
# Для PostgreSQL (продакшен)
DATABASE_URL=postgresql://user:password@localhost:5432/urlshortener

# Для SQLite (разработка)
# DATABASE_URL=sqlite:///./url_shortener.db

# Настройки сокращения URL
SHORT_URL_LENGTH=6
BASE_URL=http://localhost:8000

# Безопасность
SECRET_KEY=change-this-to-random-secret-key-in-production

# Логирование
LOG_LEVEL=INFO

